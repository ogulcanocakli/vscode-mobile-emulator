{
  "name": "vscode-mobile-emulator",
  "displayName": "VSCode Mobile Emulator",
  "description": "Embedded Android emulator panel for VSCode",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mobileEmulator.start"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mobileEmulator.start",
        "title": "Start Mobile Emulator",
        "category": "Mobile Emulator"
      }
    ],
    "keybindings": [
      {
        "command": "mobileEmulator.start",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node test/test-adb.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "keywords": [
    "android",
    "emulator",
    "mobile",
    "development"
  ],
  "author": "",
  "license": "ISC"
}

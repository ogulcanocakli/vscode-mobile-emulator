{
  "name": "vscode-mobile-emulator",
  "displayName": "Mobile Emulator",
  "description": "A VSCode extension for mobile device emulation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-mobile-emulator.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "vsce": "^2.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ogulcanocakli/vscode-mobile-emulator.git"
  },
  "homepage": "https://github.com/ogulcanocakli/vscode-mobile-emulator#readme",
  "bugs": {
    "url": "https://github.com/ogulcanocakli/vscode-mobile-emulator/issues"
  },
  "publisher": "ogulcanocakli",
  "license": "MIT"
}